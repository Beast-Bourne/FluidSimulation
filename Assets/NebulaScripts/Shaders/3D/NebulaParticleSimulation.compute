// kernels
#pragma kernel UpdatePredictions
#pragma kernel UpdateGridHash
#pragma kernel UpdateSmoothingRadii
#pragma kernel CorrectionTerms
#pragma kernel CalculateAdaptiveTimestep
#pragma kernel UpdateFusionRate
#pragma kernel NeighbourDependentProperties
#pragma kernel CalculateGravity
#pragma kernel UpdatePositions
#pragma kernel InitialiseEntropy

// Includes
#include "../GridHelper.hlsl"
#include "../InfluenceKernels.hlsl"

struct ParticleData
{
    float3 position;
    float3 predictedPos;
    float3 velocity;
    float density;
    float smoothingRadius;
    float entropy;
    float pressureCorrection;
    float balsaraFactor;
    float temperature;
    float hydroWeight;
    float meanMolecularWeight;
};

struct ParticleEntropyData
{
    float alpha;
    float soundSpeed;
    float divV;
    float fusionEnergyRate;
};

// NOTE: should optimise this later (need padding for alignment)
// compress CentreOfMass to float4 where w is mass (float 3 causes alignment issues, wasting bandwidth)
// compress centre and size to float4 where w is size
// change bool to uint
struct OctreeNode
{
    float mass;
    float3 centreOfMass;
    float3 centre;
    float size;
    bool hasChildren;
    uint firstChildIndex;
    uint parentIndex;
    uint spatialStartIndex;
};

// NOTE: change to using 3 uint3s instead of 9 uints for better memory access patterns
// look into: currently is 36 bytes but memory fetches in 32 byte chunks
struct SpatialData
{
    uint index1;
    uint hash1;
    uint key1;
    
    uint index2;
    uint hash2;
    uint key2;
    
    uint index3;
    uint hash3;
    uint key3;
};

static const int threadCount = 128;

// property buffers
RWStructuredBuffer<ParticleData> ParticleBuffer;
RWStructuredBuffer<ParticleEntropyData> EntropyDataBuffer;
RWStructuredBuffer<float3> ResultantForces;

// gravity buffers
RWStructuredBuffer<float3> GravityForceBuffer;
RWStructuredBuffer<float3> GravityCorrectionBuffer;

// timestep buffers
RWStructuredBuffer<float> DeltaTimeBuffer; // holds the per-particle adaptive timestep values
RWStructuredBuffer<float> GlobalDeltaTimeBuffer; // holds the global delta time value for the current frame (computed on a different shader that's run between kernel 4 and 5)

// debug buffers
RWStructuredBuffer<float3> DebugBuffer;

// Spatial hash buffers
// SpatialDataBuffer[i] stores the spatial hash data for the particles. stores each layer for efficient access
// SpatialOffsetDataBuffer[i] gives the index of the first particle in the SpatialDataBuffer buffer with the key matching the particle with index i
RWStructuredBuffer<SpatialData> SpatialDataBuffer;
RWStructuredBuffer<uint3> SpatialOffsetDataBuffer; // .x is the offset for stage 1, .y is the offset for stage 2, and .z is the offset for stage 3

// octree buffers
RWStructuredBuffer<OctreeNode> Octree;
RWStructuredBuffer<uint> SpatialHashes;

// spatial hashing constants
const float stage1Size;
const float stage2Size;
const float stage3Size;
const float minSizeFactor;

// general constants
const uint numParticles;
const float CFL;
const float3 boundSize;
const float damping;

// gravity constants
const float gravity;
const float particleMass;
const float BarnesHutTheta;
const float softeningLength;

// smoothing and pressure constants
const float pressureMultiplier;
const float adiabaticIndex;
const bool useDynamicSmoothingRadius;

// energy constants
const float initialTemperature;
const float protonMass;
const float boltzmannConstant;
const float coolingLambda;
const float coolingAlpha;
const float subcycles;
const float conductionCoefficient;

// viscosity constants
const float viscAlphaMax;
const float viscAlphaMin;
const float viscEpsilon;
const float viscocityMultiplier;

// fusion constants
const float fusionTempThreshold;
const float fusionDensityThreshold;
const float fusionRateCoefficient;
const float energyPerUnitMass;

// checks if a particle of the given index has collided with the outer bounds and updates its position and velocity accordingly
ParticleData HandleCollisions(ParticleData particleData)
{
    float3 pos = particleData.position;
    float3 vel = particleData.velocity;
    
    const float3 halfSize = 0.5f * boundSize;
    float3 edgeDist = halfSize - abs(pos);
    
    if (edgeDist.x < 0)
    {
        pos.x = halfSize.x * sign(pos.x);
        vel.x = -vel.x * damping;
    }
    if (edgeDist.y < 0)
    {
        pos.y = halfSize.y * sign(pos.y);
        vel.y = -vel.y * damping;
    }
    if (edgeDist.z < 0)
    {
        pos.z = halfSize.z * sign(pos.z);
        vel.z = -vel.z * damping;
    }
    
    particleData.position = pos;
    particleData.velocity = vel;
    return particleData;
}

uint3 GetIndexDataFromLayer(uint targetIndex, uint targetLayer)
{
    if (targetLayer == 1)
    {
        return uint3(SpatialDataBuffer[targetIndex].index1, SpatialDataBuffer[targetIndex].hash1, SpatialDataBuffer[targetIndex].key1);
    }
    else if (targetLayer == 2)
    {
        return uint3(SpatialDataBuffer[targetIndex].index2, SpatialDataBuffer[targetIndex].hash2, SpatialDataBuffer[targetIndex].key2);
    }
    else
    {
        return uint3(SpatialDataBuffer[targetIndex].index3, SpatialDataBuffer[targetIndex].hash3, SpatialDataBuffer[targetIndex].key3);
    }
}

uint GetSpatialOffsetFromLayer(uint key, uint targetLayer)
{
    if (targetLayer == 1) return SpatialOffsetDataBuffer[key].x;
    else if (targetLayer == 2) return SpatialOffsetDataBuffer[key].y;
    else return SpatialOffsetDataBuffer[key].z;
}

float3 CalcGravAccelFromLeafNode(uint nodeIndex, float3 particlePos, uint particleIndex)
{
    float3 gravAccel = float3(0, 0, 0);
    float sqrSoftening = softeningLength * softeningLength;
    
    uint spatialIndex = Octree[nodeIndex].spatialStartIndex;
    
    for (int i = 0; i < 8; i++)
    {
        uint hash = SpatialHashes[spatialIndex + i];
        uint key = KeyFromHash(hash, numParticles);
        uint index = GetSpatialOffsetFromLayer(key, 1);
        
        while (index < numParticles)
        {
            uint3 indexData = GetIndexDataFromLayer(index, 1);
            index++;
            
            if (indexData[2] != key) break; // if the key is wrong then exit the loop
            if (indexData[1] != hash) continue; // if the hash is wrong then move to the next index
            
            uint adjacentIndex = indexData[0];
            if (adjacentIndex == particleIndex) continue; // skips self interaction
            
            float3 offsetFromAdjacent = particlePos - ParticleBuffer[adjacentIndex].predictedPos;
            float sqrDist = dot(offsetFromAdjacent, offsetFromAdjacent);
            if (sqrDist <= 0) continue; // skips calculations to prevent a divide by zero error
            
            float dist = sqrt(sqrDist);
            float3 dir = offsetFromAdjacent / max(dist, softeningLength);
            float gravMag = -gravity * particleMass * pow(max(sqrDist, sqrSoftening), -1.5);
            gravAccel += dir * gravMag;
        }
    }
    
    return gravAccel;
}

float3 GetGravityAccelFromOctreeChildren(uint parentIndex, float3 particlePos, uint particleIndex)
{
    float3 gravAccel = float3(0,0,0);
    float sqrSoftening = softeningLength * softeningLength;
    
    uint stack[64]; // stack for storing indices to visit. This gets around the issue of recursion in compute shaders
    uint stackPtr = 0;
    
    stack[0] = parentIndex;
    stackPtr++;
    
    while (stackPtr > 0)
    {
        stackPtr -= 1;
        uint index = stack[stackPtr];
        OctreeNode node = Octree[index];
        
        if (node.mass <= 0) continue; // skips calculations if node has no mass
        
        float3 offset = node.centreOfMass - particlePos;
        float sqrDist = dot(offset, offset);
        
        if (sqrDist <= 0) continue; // skips calculations to prevent a divide by zero error
        
        float s = node.size;
        float dist = sqrt(sqrDist);
        
        if (s / dist < BarnesHutTheta)
        {
            float3 dir = offset / max(dist, softeningLength);
            float accelMag = gravity * node.mass * pow(max(sqrDist, sqrSoftening), -1.5);
            gravAccel += dir * accelMag;
        }
        else
        {
            if (node.hasChildren) // if the node has children then add them to the stack
            {
                for (int i = 0; i < 8; i++)
                {
                    stack[stackPtr] = node.firstChildIndex + i;
                    stackPtr++;
                }
            }
            else // if the node doesnt have children then get the gravity accel from the particles inside the node
            {
                gravAccel += CalcGravAccelFromLeafNode(index, particlePos, particleIndex);
            }
        }
    }
    
    return gravAccel;
}

float LambdaFunction(float temp)
{
    return coolingLambda * pow(abs(temp), coolingAlpha);
}

float ApplyCooling(float entropy, float dens, float meanMolecularWeight)
{
    float originEntropy = entropy;
    float mu_mp = meanMolecularWeight * protonMass;
    
    float timeRemaining = GlobalDeltaTimeBuffer[0];
    int step = 0;
    while (timeRemaining > 0.0f && step < subcycles)
    {
        float dt = min(timeRemaining, GlobalDeltaTimeBuffer[0] / subcycles);
        
        float temp = (mu_mp / boltzmannConstant) * entropy * pow(abs(dens), adiabaticIndex - 1);
        float Lambda = LambdaFunction(temp);
        
        float dS_dt = -(adiabaticIndex - 1) * Lambda * pow(abs(dens), 2 - adiabaticIndex) / (mu_mp * mu_mp);
        float newEntropy = entropy + (dS_dt * dt);
        
        if (newEntropy < 1e-8) { entropy = 1e-8; break; }
        
        entropy = newEntropy;
        timeRemaining -= dt;
        step++;

    }
    
    return (entropy - originEntropy);
}

float GetTargetLayerSize(float smoothRad)
{
    return (smoothRad <= stage1Size)? stage1Size :
           (smoothRad <= stage2Size)? stage2Size :
           stage3Size;
}

uint GetTargetLayer(float smoothRad)
{
    return (smoothRad <= stage1Size) ? 1 : (smoothRad <= stage2Size) ? 2 : 3;
}

// NOTE: need to tune 'eta' to get good results (do this after optimising for more particles)
float GetTargetSmoothRad(float density)
{
    const float eta = 1.2f;
    const float invDim = 1.0f / 3.0f;
    return eta * pow(abs(0.331f / density), invDim);

}

// NOTE: Maybe test the difference between density using 'h' and 'average h'
// density doesn't need to be symetrical since its a scalar but since its used in force calculations i think it might affect stability
float CalculateParticlesDensity(float3 predPos, float smoothRad, uint particleIndex)
{
    int3 originGridPos = GetGridPos3D(predPos, GetTargetLayerSize(smoothRad));
    float density = 0;
    float sqrRadius = smoothRad * smoothRad;
    
    for (int i = 0; i < 27; i++)
    {
        uint hash = HashGridPos3D(originGridPos + GridOffsets3D[i]);
        uint key = KeyFromHash(hash, numParticles);
        uint index = GetSpatialOffsetFromLayer(key, (smoothRad <= stage1Size) ? 1 : (smoothRad <= stage2Size) ? 2 : 3);
        
        while (index < numParticles)
        {
            uint3 indexData = GetIndexDataFromLayer(index, (smoothRad <= stage1Size) ? 1 : (smoothRad <= stage2Size) ? 2 : 3);
            index++;
            
            if (indexData[2] != key) break; // if the key is wrong then exit the loop
            if (indexData[1] != hash) continue; // if the hash is wrong then move to the next index
            
            uint adjacentIndex = indexData[0];
            
            if (adjacentIndex == particleIndex) { density += (WendlandC2(0, smoothRad) * particleMass); continue; }
            
            float3 offsetFromAdjacent = predPos - ParticleBuffer[adjacentIndex].predictedPos;
            float sqrDist = dot(offsetFromAdjacent, offsetFromAdjacent);
            
            if (sqrDist > smoothRad * smoothRad) continue; // if the particle is outside the smoothing radius then skip it
            
            float dist = sqrt(sqrDist);
            density += (WendlandC2(dist, smoothRad) * particleMass);
        }
    }
    
    return density;
}

float CalculateFusionRate(float temp, float density, float hydroWeight)
{
    if (temp < fusionTempThreshold) return 0.0f;
    if (density < fusionDensityThreshold) return 0.0f;
    
    // NOTE: this is a simple proton-proton fusion rate equation (does not work for CNO cycle)
    float rate = fusionRateCoefficient * pow(temp/fusionTempThreshold, 4) * density * hydroWeight * hydroWeight;
    return rate;
}

// kernel 0
// updates the predicted positions of the particles
// NOTE: look into having the predictions reflect particles off the bounds rather than just clamping them
[numthreads(threadCount,1,1)]
void UpdatePredictions(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= numParticles) return;
    
    // reset forces
    ResultantForces[id.x] = float3(0, 0, 0);
    
    ParticleData particle = ParticleBuffer[id.x];
    
    float3 PredPos = particle.position + (particle.velocity * GlobalDeltaTimeBuffer[0] * 0.2f);
    
    const float3 halfSize = 0.5f * boundSize;
    float3 edgeDist = halfSize - abs(PredPos);
    
    if (edgeDist.x < 0)
    {
        PredPos.x = halfSize.x * sign(PredPos.x);
    }
    if (edgeDist.y < 0)
    {
        PredPos.y = halfSize.y * sign(PredPos.y);
    }
    if (edgeDist.z < 0)
    {
        PredPos.z = halfSize.z * sign(PredPos.z);
    }
    particle.predictedPos = PredPos;
    ParticleBuffer[id.x] = particle;
}

// kernel 1
// Calculates the spatial hash and key for each particle and stores it in the SpatialIndices buffer
// this updates the spatial lookup as the particles move around
// After this kernel is run the SpatialIndices buffer will be sorted by key and hash before kernel 2 is run
[numthreads(threadCount,1,1)]
void UpdateGridHash(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= numParticles) return;
    SpatialOffsetDataBuffer[id.x] = uint3(numParticles, numParticles, numParticles); // reset the offsets
    uint index = id.x;
    float3 predPos = ParticleBuffer[index].predictedPos; // get predicted position
    
    // spatial hash stage 1
    int3 gridPos = GetGridPos3D(predPos, stage1Size);
    uint hash = HashGridPos3D(gridPos);
    uint key = KeyFromHash(hash, numParticles);
    SpatialDataBuffer[id.x].index1 = index;
    SpatialDataBuffer[id.x].hash1 = hash;
    SpatialDataBuffer[id.x].key1 = key;
    
    // spatial hash stage 2
    int3 gridPos2 = GetGridPos3D(predPos, stage2Size);
    uint hash2 = HashGridPos3D(gridPos2);
    uint key2 = KeyFromHash(hash2, numParticles);
    SpatialDataBuffer[id.x].index2 = index;
    SpatialDataBuffer[id.x].hash2 = hash2;
    SpatialDataBuffer[id.x].key2 = key2;
    
    // spatial hash stage 3
    int3 gridPos3 = GetGridPos3D(predPos, stage3Size);
    uint hash3 = HashGridPos3D(gridPos3);
    uint key3 = KeyFromHash(hash3, numParticles);
    SpatialDataBuffer[id.x].index3 = index;
    SpatialDataBuffer[id.x].hash3 = hash3;
    SpatialDataBuffer[id.x].key3 = key3;
}

// kernel 2
// updates the smoothing radius and density of each particle
[numthreads(threadCount, 1, 1)]
void UpdateSmoothingRadii(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= numParticles) return;
    ParticleData particle = ParticleBuffer[id.x];
    
    if (!useDynamicSmoothingRadius)
    {
        particle.smoothingRadius = stage1Size;
        particle.density = CalculateParticlesDensity(particle.predictedPos, stage1Size, id.x);
        ParticleBuffer[id.x] = particle;
        return;
    }
    
    float smoothRad = particle.smoothingRadius;
    float density = 0.0f;
    
    for (int i = 0; i < 3; i++)
    {
        density = CalculateParticlesDensity(particle.predictedPos, smoothRad, id.x);
        density = max(density, 1e-8);
        float targetSmoothRad = GetTargetSmoothRad(density);
        smoothRad = lerp(smoothRad, targetSmoothRad, 0.5f);
    }
    
    smoothRad = lerp(particle.smoothingRadius, smoothRad, 0.005f);
    particle.smoothingRadius = clamp(smoothRad, stage1Size * minSizeFactor, stage3Size);
    particle.density = CalculateParticlesDensity(particle.predictedPos, smoothRad, id.x);
    ParticleBuffer[id.x] = particle;
}

// kernel 3
// computes the balsara factor for reducing artificial viscosity in shear flows
// also compute the pressure correction term (for correcting errors from a varaible smoothing radius)
[numthreads(threadCount, 1, 1)]
void CorrectionTerms(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= numParticles) return;
    
    ParticleData particle = ParticleBuffer[id.x];
    ParticleEntropyData entropyData = EntropyDataBuffer[id.x];
    
    float smoothRad = particle.smoothingRadius;
    int3 originGridPos = GetGridPos3D(particle.predictedPos, GetTargetLayerSize(smoothRad));
    
    // variables for storing neighbour contributions
    float divV = 0.0f;
    float3 curlV = 0.0f;
    
    float sum_dW_dh = 0.0f;
    
    // neighbour loop
    for (int i = 0; i < 27; i++)
    {
        uint hash = HashGridPos3D(originGridPos + GridOffsets3D[i]);
        uint key = KeyFromHash(hash, numParticles);
        uint index = GetSpatialOffsetFromLayer(key, (smoothRad <= stage1Size) ? 1 : (smoothRad <= stage2Size) ? 2 : 3);
        
        while (index < numParticles)
        {
            // check for valid interaction
            uint3 indexData = GetIndexDataFromLayer(index, (smoothRad <= stage1Size) ? 1 : (smoothRad <= stage2Size) ? 2 : 3);
            index++;
            
            if (indexData[2] != key) break;
            if (indexData[1] != hash) continue;
            
            uint adjIndex = indexData[0];
            if (adjIndex == id.x) continue;
            
            ParticleData adjParticle = ParticleBuffer[adjIndex];
            
            float3 offsetToAdj = particle.predictedPos - adjParticle.predictedPos;
            float sqrDistToAdj = dot(offsetToAdj, offsetToAdj);
            
            float adjSmoothRad = adjParticle.smoothingRadius;
            float smoothRadValidator = max(smoothRad, adjSmoothRad);
            if (sqrDistToAdj > smoothRadValidator * smoothRadValidator) continue;
            
            // compute needed properties
            float dist = sqrt(sqrDistToAdj);
            float3 dirFromAdj = offsetToAdj / max(dist, 1e-6);
            
            float W_i = WendlandC2(dist, smoothRad);
            float W_j = WendlandC2(dist, adjSmoothRad);
            float W_ij = 0.5f * (W_i + W_j);
            
            float dw_dr_i = WendlandC2Derivative(dist, smoothRad);
            float3 gradW_i = dw_dr_i * dirFromAdj;
            float3 gradW_j = WendlandC2Derivative(dist, adjSmoothRad) * dirFromAdj;
            float3 gradW_ij = 0.5f * (gradW_i + gradW_j);
            
            // balsara factor calculations
            float m_dens = particleMass / adjParticle.density;
            float3 relVel = adjParticle.velocity - particle.velocity;
            divV += m_dens * dot(relVel, gradW_ij);
            curlV += m_dens * cross(relVel, gradW_ij);
            
            // pressure correction calculations
            sum_dW_dh += particleMass * ((3.0f * W_i + dist * dw_dr_i) / smoothRad);
        }
    }
    
    // balsara factor finalisation
    float divMag = abs(divV);
    float curlMag = length(curlV);
        
    particle.balsaraFactor = divMag / (divMag + curlMag + 1e-4);
    
    // adaptive viscosity alpha calculations
    float soundSpeed = sqrt(adiabaticIndex * particle.entropy * pow(abs(particle.density), adiabaticIndex - 1));
    
    float tau = smoothRad / (soundSpeed * 0.1f);
    float alpha = entropyData.alpha;
    float source = max(-divV, 0.0f) * (viscAlphaMax - alpha);
    alpha += (source - (alpha - viscAlphaMin) / tau) * GlobalDeltaTimeBuffer[0];
    alpha = clamp(alpha, viscAlphaMin, viscAlphaMax);
    
    entropyData.divV = divMag;
    entropyData.soundSpeed = soundSpeed;
    entropyData.alpha = alpha;
    
    // pressure correction finalisation
    float density = particle.density;
    float densityTerm = smoothRad / (3.0f * density);
    float newCorrection = 1.0f - (densityTerm * sum_dW_dh);
    newCorrection = clamp(newCorrection, 0.5f, 2.0f);
    
    float pressureTerm = (1.0f / (density * density * newCorrection));
    particle.pressureCorrection = pressureTerm;
    
    // buffer writes
    ParticleBuffer[id.x] = particle;
    EntropyDataBuffer[id.x] = entropyData;
}

// kernel 4
// calculate the adaptive timestep
[numthreads(threadCount, 1, 1)]
void CalculateAdaptiveTimestep(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= numParticles) return;
    ParticleData particle = ParticleBuffer[id.x];
    ParticleEntropyData entropyData = EntropyDataBuffer[id.x];
    
    float smoothRad = particle.smoothingRadius;
    float divV = entropyData.divV;
    float viscBeta = entropyData.alpha * 2.0f;
    
    // calculate the three criteria for the timestep
    // sound speed, viscosity and conduction all contribute to stability limits in the timestep
    float sound_dt = smoothRad / (entropyData.soundSpeed + 1e-6);
    float visc_dt = smoothRad / (entropyData.alpha * entropyData.soundSpeed + viscBeta * smoothRad * divV + 1e-6);
    float cond_dt = (smoothRad * smoothRad) / (conductionCoefficient + 1e-6);
    
    // get the minimum dt from the three criteria and store it
    float local_dt = CFL * min(sound_dt, min(visc_dt, cond_dt));
    DeltaTimeBuffer[id.x] = local_dt;
}

// kernel 5
// calculate fusion rates and mass weights
[numthreads(threadCount, 1, 1)]
void UpdateFusionRate(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= numParticles) return;
    ParticleData particle = ParticleBuffer[id.x];
    ParticleEntropyData entropyData = EntropyDataBuffer[id.x];
    
    // calculate temperature this frame
    particle.temperature = (protonMass * particle.meanMolecularWeight / boltzmannConstant) * particle.entropy * pow(abs(particle.density), adiabaticIndex - 1);
    
    float fusionRate = CalculateFusionRate(particle.temperature, particle.density, particle.hydroWeight);
    float hydroChange = fusionRate * GlobalDeltaTimeBuffer[0] / energyPerUnitMass;
    
    float hydroWeight = max(particle.hydroWeight - hydroChange, 0.0f);
    float heliumWeight = min(1.0f - hydroWeight, 1.0f);
    float meanMolecularWeight = 1.0f / (2.0f * hydroWeight + 0.75f * heliumWeight);
    
    particle.hydroWeight = hydroWeight;
    particle.meanMolecularWeight = meanMolecularWeight;
    entropyData.fusionEnergyRate = fusionRate;

    ParticleBuffer[id.x] = particle;
    EntropyDataBuffer[id.x] = entropyData;
}

// kernel 6
// calculates all neighbour dependent properties (pressure force, viscosity force, entropy and XSPH)
// XSPH is a velocity correction that reduces numerical instability
[numthreads(threadCount, 1, 1)]
void NeighbourDependentProperties(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= numParticles) return;
    ParticleData particle = ParticleBuffer[id.x];
    ParticleEntropyData entropyData = EntropyDataBuffer[id.x];
    
    float smoothRad = particle.smoothingRadius;
    
    int3 originGridPos = GetGridPos3D(particle.predictedPos, GetTargetLayerSize(10.5f));
    
    // variables for storing neighbour contributions
    float viscTerm = 0.0;
    float condTerm = 0.0;
    
    float3 viscosityForce = float3(0.0f, 0.0f, 0.0f);
    
    float pressure_i = particle.entropy * pow(abs(particle.density), adiabaticIndex);
    float3 pressureForce = float3(0, 0, 0);
    
    float3 xsph = float3(0, 0, 0);
    
    // neighbour loop
    for (int i = 0; i < 27; i++)
    {
        uint hash = HashGridPos3D(originGridPos + GridOffsets3D[i]);
        uint key = KeyFromHash(hash, numParticles);
        uint index = GetSpatialOffsetFromLayer(key, 3);
        
        while (index < numParticles)
        {
            // check for valid interaction
            uint3 indexData = GetIndexDataFromLayer(index, 3);
            index++;
            
            if (indexData[2] != key) break;
            if (indexData[1] != hash) continue;
            
            uint adjIndex = indexData[0];
            if (adjIndex == id.x) continue;
            
            ParticleData adjParticle = ParticleBuffer[adjIndex];
            ParticleEntropyData adjEntropyData = EntropyDataBuffer[adjIndex];
            
            float3 offsetFromAdj = particle.predictedPos - adjParticle.predictedPos;
            float sqrDistToAdj = dot(offsetFromAdj, offsetFromAdj);
            
            float smoothRadValidator = max(smoothRad, adjParticle.smoothingRadius);
            if (sqrDistToAdj > smoothRadValidator * smoothRadValidator) continue;
            
            // compute properties for the interaction
            float dist = sqrt(sqrDistToAdj);
            float3 dirFromAdj = offsetFromAdj / max(dist, 1e-6);
            
            float w_i = WendlandC2(dist, smoothRad);
            float w_j = WendlandC2(dist, adjParticle.smoothingRadius);
            float w_ij = 0.5f * (w_i + w_j);
            
            float3 gradW_i = WendlandC2Derivative(dist, smoothRad) * dirFromAdj;
            float3 gradW_j = WendlandC2Derivative(dist, adjParticle.smoothingRadius) * dirFromAdj;
            float3 gradW_ij = 0.5 * (gradW_i + gradW_j);
            
            float densFactor = pow(abs(particle.density), adiabaticIndex - 1);
            float adjDensFactor = pow(abs(adjParticle.density), adiabaticIndex - 1);
            
            float3 relVel = particle.velocity - adjParticle.velocity;
            float velDivTerm = dot(relVel, gradW_ij);
            
            // Entropy calculations
            // conduction heating term
            float tempDiff = particle.temperature - adjParticle.temperature;
            float conductionFlux = (particleMass * conductionCoefficient * tempDiff * dot(offsetFromAdj, gradW_ij)) / (particle.density * adjParticle.density * dist);
            float entropyFactor = (adiabaticIndex - 1) / densFactor;
            condTerm += (conductionFlux * entropyFactor);
            
            // viscosity only applies for converging particles to model shock dissipation
            float relVelAlongOffset = dot(relVel, dirFromAdj);
            if (relVelAlongOffset < 0)
            {
                float avgSoundSpeed = 0.5f * (entropyData.soundSpeed + adjEntropyData.soundSpeed);
                float avgAlpha = 0.5f * (entropyData.alpha + adjEntropyData.alpha);
                float avgBeta = 2.0f * avgAlpha;
                
                float avgSmoothRad = 0.5f * (smoothRad + adjParticle.smoothingRadius);
                float avgDensity = 0.5f * (particle.density + adjParticle.density);
                float massFactor = (avgSmoothRad * relVelAlongOffset) / (dist + (viscEpsilon * avgSmoothRad * avgSmoothRad));
                massFactor = clamp(massFactor, -5.0f, 0.0f);
                
                float avgBalsara = 0.5f * (particle.balsaraFactor + adjParticle.balsaraFactor);
                float artVisc = avgBalsara * (-avgAlpha * avgSoundSpeed * massFactor + avgBeta * massFactor * massFactor) / avgDensity;
            
                float3 forceTerm = -particleMass * artVisc * gradW_ij;
                viscosityForce += forceTerm;
                
                float compWork = max(velDivTerm, 0.0f);
                float viscosityTerm = 0.5f * particleMass * artVisc * compWork;
                float entropyChange = viscosityTerm * entropyFactor * viscocityMultiplier;
                viscTerm += entropyChange;
            }
            
            // pressure calculations
            float pressure_j = particle.entropy * pow(abs(adjParticle.density), adiabaticIndex);
            pressureForce += -particleMass * ((particle.pressureCorrection * pressure_i * gradW_i) + (adjParticle.pressureCorrection * pressure_j * gradW_j));
            
            // XSPH calculations
            float avgDensity = 0.5f * (particle.density + adjParticle.density);
            xsph += (adjParticle.velocity - particle.velocity) * w_ij * (particleMass / avgDensity);
        }
    }
    
    // entropy finalisation
    float entropyFactor = (adiabaticIndex - 1) * pow(abs(particle.density), 1-adiabaticIndex);
    float fusionTerm = entropyData.fusionEnergyRate * entropyFactor;
    fusionTerm = min(fusionTerm, particle.entropy * 0.005f);

    float change = (viscTerm + condTerm + fusionTerm) * GlobalDeltaTimeBuffer[0];
    float coolingChange = ApplyCooling(particle.entropy, particle.density, particle.meanMolecularWeight);
    change += coolingChange;
    particle.entropy += change;
    
    // forces finalisation
    float3 totalForce = (pressureForce * pressureMultiplier) + (viscosityForce * viscocityMultiplier);
    
    // XSPH finalisation
    particle.velocity += xsph * 0.01f;
    
    // buffer writes
    ParticleBuffer[id.x] = particle;
    ResultantForces[id.x] += totalForce;
}

// kernel 7
// calculates the gravity force between the particles
[numthreads(threadCount,1,1)]
void CalculateGravity(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= numParticles) return;
    
    float3 gravityAccel = float3(0, 0, 0);
    
    for (int i = 1; i < 9; i++)
    {
        gravityAccel += GetGravityAccelFromOctreeChildren(i, ParticleBuffer[id.x].predictedPos, id.x);
    }
    
    ResultantForces[id.x] += gravityAccel;
    GravityForceBuffer[id.x] = gravityAccel;
}

// kernel 8
// updates the positions of all particles and checks for collisions with the bounds
[numthreads(threadCount,1,1)]
void UpdatePositions(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= numParticles) return;
    
    ParticleData particle = ParticleBuffer[id.x];
    
    particle.velocity += (ResultantForces[id.x] + GravityCorrectionBuffer[0]) * GlobalDeltaTimeBuffer[0];
    particle.position += particle.velocity * GlobalDeltaTimeBuffer[0];
    
    ParticleBuffer[id.x] = HandleCollisions(particle);
}

// kernel 9
// run once at the start of the simulation to set the inital entropy values
[numthreads(threadCount, 1, 1)]
void InitialiseEntropy(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= numParticles) return;
    
    ParticleData particle = ParticleBuffer[id.x];
    
    float entropy = ((boltzmannConstant * initialTemperature) / (protonMass * particle.meanMolecularWeight)) * pow(abs(particle.density), 1 - adiabaticIndex);

    particle.entropy = entropy;
    ParticleBuffer[id.x] = particle;
}